{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": 2,
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/(.*)", "dest": "/dist/main.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}