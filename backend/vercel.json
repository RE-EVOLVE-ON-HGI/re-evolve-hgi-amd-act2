{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/build-step",
      "config": {
        "cmd": "npm run build"
      }
    },
    {
      "src": "dist/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/(.*)", "dest": "/dist/main.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
